# Database Configuration
# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgres://postgres:postgres@db:5432/cosplit-api-development?schema=public"

# Environment
NODE_ENV=development
PORT=3000

# CORS origins (comma-separated)
CORS_ORIGINS=https://app.example.com,https://example.com

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30

# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: https://your-api.com/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-api.com/auth/google/callback

# Frontend URL — used to redirect after Google OAuth callback
FRONTEND_URL=https://your-app.com

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=your-bucket-name
# Optional: Custom public URL for accessing uploaded files
# R2_PUBLIC_BASE_URL=https://your-custom-domain.com

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Sentry (optional)
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Gemini (optional)
# GEMINI_API_KEY=your-gemini-key
