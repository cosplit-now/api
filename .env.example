# Database Configuration
# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgres://postgres:postgres@db:5432/cosplit-api-development?schema=public"

# Environment
NODE_ENV=development
PORT=3000

# Better Auth Configuration
# Generate a random secret key (32+ characters recommended)
# You can use: openssl rand -base64 32
BETTER_AUTH_SECRET=tV7xhnzzbQ6giyobJ95nDvgE5wCqVx4p

# Base URL of your application
# Development: http://localhost:3000/auth
# Production: https://yourdomain.com/auth
BETTER_AUTH_URL=http://localhost:3000/auth

# Cookie domain for cross-subdomain auth (optional)
# Example: xinqi.mu
SESSION_COOKIE_DOMAIN=

# CORS origins (comma-separated)
CORS_ORIGINS=https://app.example.com,https://example.com

# Trusted origins for auth (comma-separated)
TRUSTED_ORIGINS=https://app.example.com,https://api.example.com,https://example.com

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=your-bucket-name
# Optional: Custom public URL for accessing uploaded files
# R2_PUBLIC_BASE_URL=https://your-custom-domain.com

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Sentry (optional)
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Gemini (optional)
# GEMINI_API_KEY=your-gemini-key
