DATABASE_URL=postgresql://postgres:postgres@localhost:55432/cosplit-api-test
NODE_ENV=test
PORT=3000

CORS_ORIGINS=http://localhost:5173

# JWT — test values, never used for real auth in unit/e2e tests
JWT_SECRET=test-jwt-secret-key-at-least-32-chars!!
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30

# Google OAuth — mocked in tests, these values are never used
API_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
FRONTEND_CALLBACK_ALLOWLIST=http://localhost:5173/auth/callback

REDIS_HOST=localhost
REDIS_PORT=56379

# R2 / S3 — mocked in tests, these values are never used
R2_ACCOUNT_ID=test
R2_ACCESS_KEY_ID=test
R2_SECRET_ACCESS_KEY=test
R2_BUCKET=test-bucket
R2_PUBLIC_BASE_URL=https://test-r2.example.com
