// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipts      Receipt[]
  demoReceipts  DemoReceipt[]
  attachments   ReceiptAttachment[]
  refreshTokens RefreshToken[]

  @@map("user")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_token")
}

// uploaded | ocr_processing | ocr_done | ocr_failed | confirme
enum DemoReceiptStatus {
  uploaded
  ocr_processing
  ocr_done
  ocr_failed
  confirmed
}

model DemoReceipt {
  id          String            @id @default(cuid())
  status      DemoReceiptStatus
  imageUrl    String
  ocrResult   Json?
  finalResult Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Receipt {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeName    String?
  storeAddress String?
  receiptDate  DateTime?

  subtotal    Decimal? @db.Decimal(14, 2)
  discount    Decimal? @db.Decimal(14, 2)
  taxAmount   Decimal? @db.Decimal(14, 2)
  totalAmount Decimal? @db.Decimal(14, 2)

  ocrResult Json?
  ocrStatus OcrStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments  ReceiptAttachment[]
  items        ReceiptItem[]
  participants Participant[]
  allocations  Allocation[]

  @@index([userId])
  @@map("receipt")
}

enum OcrStatus {
  pending
  processing
  completed
  failed
}

model ReceiptAttachment {
  id String @id @default(cuid())

  key          String
  bucket       String
  url          String
  contentType  String?
  sizeBytes    Int?
  originalName String?

  sortOrder Int              @default(0)
  notes     String?
  status    AttachmentStatus @default(pending)
  expiresAt DateTime?

  receiptId String?
  receipt   Receipt? @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receiptId])
  @@index([userId])
  @@map("receipt_attachment")
}

model ReceiptItem {
  id          String   @id @default(cuid())
  name        String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(14, 2)
  totalPrice  Decimal  @db.Decimal(14, 2)
  discount    Decimal? @db.Decimal(14, 2)
  description String?
  category    String?
  sortOrder   Int      @default(0)
  taxExempt   Boolean  @default(false)
  rawData     Json?

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  allocations Allocation[]

  @@index([receiptId])
  @@map("receipt_item")
}

model Participant {
  id      String  @id @default(cuid())
  name    String
  isPayer Boolean @default(false)

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  allocations Allocation[]

  @@index([receiptId])
  @@map("participant")
}

model Allocation {
  id            String         @id @default(cuid())
  type          AllocationType
  participantId String
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  receiptItemId String
  receiptItem   ReceiptItem    @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
  receiptId     String
  receipt       Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  value  Decimal @db.Decimal(14, 2)
  amount Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([participantId, receiptItemId])
  @@index([receiptId])
  @@index([participantId])
  @@map("allocation")
}

enum AllocationType {
  equal
  shares
  custom
}

enum AttachmentStatus {
  pending
  attached
  expired
}
